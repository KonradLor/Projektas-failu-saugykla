# ============================================
# KonradVault - Environment Variables šablonas
# ============================================
# 1. Nukopijuok šitą failą į .env: cp .env.example .env
# 2. Sugeneruok master_key ir secret_key:
#    python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 3. Užpildyk reikšmes žemiau
# 4. NIEKADA neturi .env failo prikomituot į git!


# ----- APLIKACIJOS METADUOMENYS -----
APP_NAME=KonradVault
APP_VERSION=0.1.0
DEBUG=False


# ----- SAUGUMO RAKTAI (PRIVALOMI!) -----
# Master key - failų šifravimui (PRARANDANT - VISI FAILAI PRARASTI!)
MASTER_KEY=PAKEISK_MANE_SUGENERUOTU_RAKTU

# Secret key - session cookie pasirašymui
SECRET_KEY=PAKEISK_MANE_KITU_SUGENERUOTU_RAKTU


# ----- DUOMENŲ BAZĖ -----
# Lokaliai: sqlite:///./konradvault.db
# Production: sqlite:////var/konradvault/konradvault.db
DATABASE_URL=sqlite:///./konradvault.db
DATABASE_ECHO=False


# ----- FAILŲ SAUGYKLA -----
# Lokaliai: ./encrypted
# Production: /var/konradvault/encrypted
ENCRYPTED_FILES_DIR=./encrypted

# Lokaliai: ./logs
# Production: /var/log/konradvault
LOG_DIR=./logs

# Failų limitai
MAX_FILE_SIZE_MB=500
MAX_STORAGE_PER_USER_MB=2048
ENCRYPTION_CHUNK_SIZE=65536


# ----- AUTENTIFIKACIJA -----
SESSION_EXPIRE_HOURS=24
TEMP_TOKEN_EXPIRE_MINUTES=5
MAX_LOGIN_ATTEMPTS=5

# Argon2 parametrai (ant ARM serverio gali tekti sumažinti)
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4


# ----- SERVERIO NUSTATYMAI -----
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
